{
	"layer": "top",
	"modules-left": ["custom/launcher","cpu","memory","custom/media","tray"],
	"modules-center": ["hyprland/workspaces"],
	"modules-right": ["custom/updates","backlight","pulseaudio","clock", "battery","custom/power"],

	"pulseaudio": {
		"tooltip": false,
		"scroll-step": 5,
		"format": "{icon} {volume}%",
		"format-muted": "{icon} {volume}%",
		"on-click":"pactl set-sink-mute @DEFAULT_SINK@ toggle",
		"format-icons": {
			"default": ["пЂ¦", "пЂ§", "пЂЁ"]
		}
	},
    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "warp-on-scroll": false,
        "format": "{name}",
        "persistent-workspaces": {
            "DP-1": [1, 2, 3, 4, 5],
            "DP-2": [1, 2, 3, 4, 5],
        },
        "format-icons": {
            // "1": "п„ ",
            // "2": "п‰Ё",
            // "3": "п„Ў",
            // "4": "п†ј",
            // "5": "пЃµ",
            "urgent": "пЃЄ",
            "active": "п†’",
            "default": "п„‘"
        }
    },
	"network": {
		"tooltip": false,
		"format-wifi": "п‡«  {essid}",
		"format-ethernet": ""
	},
	"backlight": {
		"tooltip": false,
		"format": "пѓ« {}%",
		"interval":1,
        "on-scroll-up": "light -A 5",
		"on-scroll-down": "light -U 5"
	},
    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 20
        },
        "format": "{icon}  {capacity}%",
        "format-charging": "п‡¦ {capacity}%",
        "format-plugged": "п‡¦ {capacity}%",
        "format-alt": "{time} {icon}",
        "format-icons": ["п‰„", "п‰ѓ", "п‰‚", "п‰Ѓ", "п‰Ђ"]
    },
	"tray":{
		"icon-size":18,
		"spacing": 10
	},
    "clock": {
        "format": "пЂ—  {:%I:%M %p  п—µ %d/%m/%Y}"
        //"format": "{:пЂ— %I:%M }"
    },
    "cpu": {
        "interval": 15,
        "format": "п‹› {}%",
        "max-length": 10
    },
    "memory": {
        "interval": 30,
        "format": "пѓ‰ {}%",
        "max-length": 10
    },
    "custom/media": {
        "interval": 30,
        "format": "{icon} {}",
        "return-type": "json",
        "max-length": 20,
        "format-icons": {
            "spotify": "п†ј ",
            "default": "пў… "
        },
        "escape": true,
        "exec": "$HOME/.config/system_scripts/mediaplayer.py 2> /dev/null",
        "on-click": "playerctl play-pause"
    },
    "custom/launcher":{
        "format": "пЊѓ ",
        "on-click": "bash ~/.config/rofi/launchers/type-3/launcher.sh",
        "on-click-right": "killall rofi"
    },
    "custom/power":{
        "format": "п„ё ",
        "on-click": "bash ~/.config/rofi/powermenu/type-2/powermenu.sh",
    },
    "custom/updates":{
        "format": "{} Update(s)",
        "exec": "checkupdates | wc -l",
        "exec-if": "[[ $(checkupdates | wc -l) != 0 ]]",
        "interval": 15,
        "on-click": "alacritty -e sudo pacman -Syu && notify-send 'The system has been updated' "
    },
    "custom/wallpaper":{
        "format":"пЂѕ ",
        "on-click": "bash ~/.config/system_scripts/pkill_bc"
    }
}
